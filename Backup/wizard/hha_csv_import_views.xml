<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- CSV Import Wizard Form View -->
    <record id="view_hha_csv_import_form" model="ir.ui.view">
        <field name="name">hha.csv.import.form</field>
        <field name="model">hha.csv.import</field>
        <field name="arch" type="xml">
            <form string="Import HHA Provider Data">
                <group>
                    <group>
                        <field name="csv_file" filename="csv_filename"/>
                        <field name="csv_filename" invisible="1"/>
                        <field name="update_existing"/>
                    </group>
                </group>
                <div class="alert alert-info" role="alert">
                    <strong>Expected CSV Columns:</strong>
                    <br/>HHA CCN, HHA Brand Name, HHA ID Owner, HHA Name Owner, HHA DBA Owner,
                    HHA NPI, HHA ID, HHA Name, HHA DBA, HHA Address, HHA City, HHA Zip,
                    HHA Fips, HHA County, HHA State, HHA State Cd, HHA CBSA, HHA Rating,
                    HHA Auth Person, HHA Auth Person Desgn, HHA Auth Person Tele
                    <br/><br/>
                    <strong>Required:</strong> HHA CCN, HHA Name
                </div>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_hha_csv_import" model="ir.actions.act_window">
        <field name="name">Import HHA CSV</field>
        <field name="res_model">hha.csv.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
