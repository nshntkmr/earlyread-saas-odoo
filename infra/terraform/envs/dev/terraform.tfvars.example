# Copy this file to terraform.tfvars (gitignored) and fill in your values.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# ─── Required ─────────────────────────────────────────────────────────────────

subscription_id = "00000000-0000-0000-0000-000000000000"

# Allow your public IP through the Key Vault + Storage firewalls so Terraform
# can seed secrets and the Files share from your laptop.  Required while
# public-with-firewall mode is enabled; check yours with:
#   (Invoke-WebRequest ifconfig.me -UseBasicParsing).Content
# Replace with your actual IP before copying to terraform.tfvars.
allowed_ips = ["YOUR.PUBLIC.IP.HERE/32"]

# ─── M1 Optional overrides ────────────────────────────────────────────────────

# location          = "eastus2"
# vnet_cidr         = "10.10.0.0/16"
# aks_subnet_cidr   = "10.10.0.0/22"
# pg_subnet_cidr    = "10.10.4.0/24"
# appgw_subnet_cidr = "10.10.5.0/24"
# pe_subnet_cidr    = "10.10.6.0/24"

# ─── M2 Optional overrides ────────────────────────────────────────────────────

# pg_admin_username             = "psadmin"
# pg_sku_name                   = "B_Standard_B1ms"
# pg_storage_mb                 = 32768
# pg_backup_retention_days      = 7
# pg_geo_redundant_backup_enabled = false
# pg_pgbouncer_enabled          = false
# pg_database_name              = "posterra_dev"
# kv_name                       = "earlyread-saas-dev-kv"
# filestore_storage_name        = "earlyreaddevfseread"
# filestore_quota_gb            = 100

# ─── M3 Optional overrides ────────────────────────────────────────────────────

# acr_name             = "earlyreadsaasacreread"
# kubernetes_version   = "1.34.6"
# pod_cidr             = "100.64.0.0/16"
# system_vm_size       = "Standard_D4as_v5"   # AKS minimum for system pool
# system_min_count     = 2                    # AKS minimum
# system_max_count     = 2                    # Dev: fixed at 2
# user_vm_size         = "Standard_D2as_v5"
# user_min_count       = 1
# user_max_count       = 2
# admin_group_object_ids = []                 # Azure AD groups for system:masters
# cluster_admin_oids     = []                 # Principal OIDs for Azure RBAC cluster admin
# appgw_sku            = "Standard_v2"        # 'Standard_v2' (no WAF, ~$180/mo) or 'WAF_v2' (~$324/mo)
# waf_mode             = "Detection"          # Only used when appgw_sku = WAF_v2
