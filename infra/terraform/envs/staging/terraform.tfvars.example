# Copy this file to terraform.tfvars (gitignored) and fill in your values.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# ─── Required ─────────────────────────────────────────────────────────────────

subscription_id = "00000000-0000-0000-0000-000000000000"

allowed_ips = ["YOUR.PUBLIC.IP.HERE/32"]

# ─── M1 Optional overrides ────────────────────────────────────────────────────

# location          = "eastus2"
# vnet_cidr         = "10.20.0.0/16"
# aks_subnet_cidr   = "10.20.0.0/22"
# pg_subnet_cidr    = "10.20.4.0/24"
# appgw_subnet_cidr = "10.20.5.0/24"
# pe_subnet_cidr    = "10.20.6.0/24"

# ─── M2 Optional overrides ────────────────────────────────────────────────────

# pg_admin_username             = "psadmin"
# pg_sku_name                   = "GP_Standard_D2ds_v5"
# pg_storage_mb                 = 65536
# pg_backup_retention_days      = 35
# pg_geo_redundant_backup_enabled = true
# pg_pgbouncer_enabled          = true
# pg_database_name              = "posterra_staging"
# kv_name                       = "earlyread-saas-stg-kv"
# filestore_storage_name        = "earlyreadstgfseread"
# filestore_quota_gb            = 100

# ─── M3 Optional overrides — staging prod-replica sizing ──────────────────────

# acr_name             = "earlyreadsaasacreread"
# kubernetes_version   = "1.34.6"
# pod_cidr             = "100.64.0.0/16"
# system_vm_size       = "Standard_D4as_v5"
# system_min_count     = 2
# system_max_count     = 3                    # Staging: autoscale 2-3
# user_vm_size         = "Standard_D4as_v5"   # Staging: prod-replica D4
# user_min_count       = 2
# user_max_count       = 3
# admin_group_object_ids = []
# cluster_admin_oids     = []
# waf_mode             = "Detection"
