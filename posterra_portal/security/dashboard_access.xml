<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        ACL for Phase 0 models: dashboard.page, dashboard.page.tab, dashboard.page.filter.

        We use  model= + search=  rather than  ref="model_dashboard_page"  because
        ir.model.data xmlids for brand-new models are not yet committed when the
        ir.model.access.csv is processed during the same upgrade cycle.
        Searching ir.model by its 'model' field (technical name) is always safe.
    -->

    <!-- ── dashboard.page ──────────────────────────────────────────────── -->
    <record id="access_dashboard_page_portal" model="ir.model.access">
        <field name="name">dashboard.page portal</field>
        <field name="model_id" model="ir.model" search="[('model','=','dashboard.page')]"/>
        <field name="group_id" ref="posterra_portal.group_posterra_user"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="access_dashboard_page_admin" model="ir.model.access">
        <field name="name">dashboard.page admin</field>
        <field name="model_id" model="ir.model" search="[('model','=','dashboard.page')]"/>
        <field name="group_id" ref="posterra_portal.group_posterra_admin"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

