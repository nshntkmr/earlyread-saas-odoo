<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Geo filters (State / County / City) are seeded with noupdate="0" so the
        model_id + field_id links to hha.provider are always populated on upgrade.

        Year / Payer filters are seeded with noupdate="1" as structural stubs.
        Admin must open each page form and set the Table + Column to point at
        whatever data table holds the year/payer values for their dataset.
    -->

