<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level menu -->
    <menuitem id="menu_posterra_root"
              name="Posterra"
              web_icon="posterra_portal,static/description/icon.png"
              groups="posterra_portal.group_posterra_admin"
              sequence="100"/>

    <!-- Submenu: Configuration -->
    <menuitem id="menu_posterra_config"
              name="Configuration"
              parent="menu_posterra_root"
              sequence="10"/>

    <!-- Submenu: HHA Providers -->
    <menuitem id="menu_hha_providers"
              name="HHA Providers"
              parent="menu_posterra_config"
              action="action_hha_provider"
              sequence="10"/>

    <!-- Submenu: Scope Groups -->
    <menuitem id="menu_hha_scope_groups"
              name="Scope Groups"
              parent="menu_posterra_config"
              action="action_hha_scope_group"
              sequence="15"/>

    <!-- Submenu: Import CSV -->
    <menuitem id="menu_hha_csv_import"
              name="Import HHA CSV"
              parent="menu_posterra_config"
              action="action_hha_csv_import"
              sequence="20"/>

    <!-- Submenu: Create Portal User -->
    <menuitem id="menu_create_portal_user"
              name="Create Portal User"
              parent="menu_posterra_config"
              action="action_posterra_create_portal_user"
              sequence="30"/>

    <!-- ================================================================ -->
    <!-- Dashboard configuration menus.                                   -->
    <!-- These live HERE (not in their respective views/*_views.xml      -->
    <!-- files) because they reference menu_posterra_config (defined     -->
    <!-- above) — and Odoo loads data files in manifest order. Defining  -->
    <!-- them inside files loaded BEFORE menuitems.xml caused fresh      -->
    <!-- `odoo -i posterra_portal` to fail with                           -->
    <!--   ValueError: External ID not found: menu_posterra_config        -->
    <!-- (M5 first-install bug). Actions referenced below stay in their   -->
    <!-- original *_views.xml files, which load earlier in the manifest. -->
    <!-- ================================================================ -->

    <!-- Submenu: Apps -->
    <menuitem id="menu_saas_apps"
              name="Apps"
              parent="menu_posterra_config"
              action="action_saas_app"
              sequence="1"/>

    <!-- Submenu: Nav Sections -->
    <menuitem id="menu_dashboard_nav_sections"
              name="Nav Sections"
              parent="menu_posterra_config"
              action="action_dashboard_nav_section"
              sequence="3"/>

    <!-- Submenu: Dashboard Pages -->
    <menuitem id="menu_dashboard_pages"
              name="Dashboard Pages"
              parent="menu_posterra_config"
              action="action_dashboard_page"
              sequence="5"/>

    <!-- Submenu: Page Sections -->
    <menuitem id="menu_dashboard_page_sections"
              name="Page Sections"
              parent="menu_posterra_config"
              action="action_dashboard_page_section"
              sequence="5"/>

    <!-- Submenu: Dashboard Widgets -->
    <menuitem id="menu_dashboard_widgets"
              name="Dashboard Widgets"
              parent="menu_posterra_config"
              action="action_dashboard_widget"
              sequence="6"/>

    <!-- Submenu: Page Templates -->
    <menuitem id="menu_page_templates"
              name="Page Templates"
              parent="menu_posterra_config"
              action="action_page_template"
              sequence="25"/>

</odoo>
