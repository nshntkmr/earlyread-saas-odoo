# Build context exclusions for `az acr build` / `docker build`.
# Keeps the upload small + safe. The image only needs the two addon
# directories + infra/docker/. Everything else here is noise or sensitive.

# ── Version control ──────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Claude / agent worktrees + session data ──────────────────────────────────
# CRITICAL: .claude/worktrees/ holds ~20 full copies of the repo. Excluding
# this is the single biggest context-size win.
.claude/

# ── Terraform — infra-as-code never belongs in the app image ────────────────
infra/terraform/

# ── Python bytecode + virtualenvs ────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/.venv/
**/venv/

# ── Node — node_modules is huge; the committed dist/ is what ships ──────────
**/node_modules/

# ── Logs, plans, local state ─────────────────────────────────────────────────
**/*.log
**/*.tfplan
**/*.tfstate
**/*.tfstate.*

# ── Local secrets / env files ────────────────────────────────────────────────
**/*.tfvars
!**/*.tfvars.example
**/.env
**/.env.*

# ── OS / editor cruft ────────────────────────────────────────────────────────
**/.DS_Store
**/Thumbs.db
**/*.swp
**/*~

# ── Odoo local runtime data (if any exists from local dev) ──────────────────
**/filestore/
**/sessions/

# ── This file + the Dockerfile itself ────────────────────────────────────────
.dockerignore
Dockerfile
