<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         DATABASE CONNECTION — List View
         ════════════════════════════════════════════════════════════════ -->
    <record id="view_dashboard_connection_list" model="ir.ui.view">
        <field name="name">dashboard.connection.list</field>
        <field name="model">dashboard.connection</field>
        <field name="arch" type="xml">
            <list string="Database Connections">
                <field name="name"/>
                <field name="engine"/>
                <field name="host"/>
                <field name="database"/>
                <field name="is_active"/>
                <field name="last_test_result"/>
                <field name="last_test_at"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         DATABASE CONNECTION — Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="view_dashboard_connection_form" model="ir.ui.view">
        <field name="name">dashboard.connection.form</field>
        <field name="model">dashboard.connection</field>
        <field name="arch" type="xml">
            <form string="Database Connection">
                <header>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object"
                            class="btn-primary"
                            icon="fa-plug"/>
                    <button name="action_invalidate_cache"
                            string="Invalidate Cache"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"
                            help="Drop the cached client on this Odoo worker. Use after rotating the password under password_param_key, or after a cluster restart."/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   placeholder="e.g. ClickHouse — Production"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="engine"/>
                            <field name="security_profile"
                                   invisible="engine != 'snowflake'"/>
                            <field name="is_active"/>
                            <field name="requires_tenant_filter"
                                   invisible="engine == 'snowflake'"/>
                            <!-- ``options`` to suppress the locale
                                 thousands separator on integer fields
                                 doesn't behave consistently across
                                 Odoo versions. The Char-typed ``port``
                                 field below avoids the issue entirely.
                                 ``query_timeout_seconds`` stays Integer
                                 because 30 doesn't trip the separator
                                 (formatting kicks in at 4+ digits). -->
                            <field name="query_timeout_seconds"/>
                        </group>
                        <group string="Endpoint" invisible="engine == 'snowflake'">
                            <field name="host"
                                   placeholder="e.g. ch-prod.example.azure.com"/>
                            <field name="port"/>
                            <field name="database"
                                   placeholder="e.g. posterra_analytics"/>
                            <field name="use_tls"/>
                        </group>
                        <group string="Snowflake" invisible="engine != 'snowflake'">
                            <field name="sf_account"
                                   placeholder="e.g. xy12345.us-east-1"/>
                            <field name="sf_warehouse"/>
                            <field name="database"
                                   placeholder="Snowflake database"/>
                            <field name="sf_db_schema"/>
                            <field name="sf_role"/>
                            <field name="auth_method"/>
                        </group>
                    </group>
                    <group string="Authentication" invisible="engine == 'snowflake'">
                        <field name="username"
                               placeholder="e.g. app_user"/>
                        <field name="password"
                               password="True"
                               placeholder="paste the database password here"/>
                        <field name="password_param_key"
                               placeholder="leave blank unless using ir.config_parameter"/>
                        <p class="text-muted" colspan="2">
                            Type the password directly into the
                            <strong>Password</strong> field above for the
                            common case. The
                            <strong>Password Config Key</strong> field
                            is optional — only used when you want the
                            secret stored in
                            <code>ir.config_parameter</code> (or an
                            external secret manager) instead of on
                            this record. If both are set, the direct
                            password wins.
                        </p>
                    </group>
                    <group string="Snowflake Authentication"
                           invisible="engine != 'snowflake'">
                        <field name="username" placeholder="Snowflake user"/>
                        <field name="sf_password" password="True"
                               invisible="auth_method != 'password'"
                               placeholder="dev only — prefer the Config Key in prod"/>
                        <field name="sf_password_param_key"
                               invisible="auth_method != 'password'"
                               placeholder="env / Key-Vault name holding the password"/>
                        <field name="sf_private_key"
                               invisible="auth_method != 'key_pair'"
                               placeholder="dev only — paste PEM; prefer the Config Key in prod"/>
                        <field name="sf_private_key_passphrase" password="True"
                               invisible="auth_method != 'key_pair'"/>
                        <field name="sf_private_key_param_key"
                               invisible="auth_method != 'key_pair'"
                               placeholder="env / Key-Vault name holding the PEM key"/>
                        <field name="sf_passphrase_param_key"
                               invisible="auth_method != 'key_pair'"
                               placeholder="env / Key-Vault name holding the passphrase"/>
                        <p class="text-muted" colspan="2">
                            Production: leave the direct key/password blank and
                            set the corresponding <strong>Config Key</strong>
                            (resolved env-first from Key Vault). The secret
                            fields are restricted to System Administrators.
                        </p>
                    </group>
                    <group string="Last Test">
                        <field name="last_test_result" readonly="1"/>
                        <field name="last_test_at" readonly="1"/>
                        <field name="configuration_verified" readonly="1"
                               invisible="engine != 'snowflake'"/>
                        <field name="configuration_verified_at" readonly="1"
                               invisible="engine != 'snowflake'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         DATABASE CONNECTION — Action + Menu
         ════════════════════════════════════════════════════════════════ -->
    <record id="action_dashboard_connection" model="ir.actions.act_window">
        <field name="name">Database Connections</field>
        <field name="res_model">dashboard.connection</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add an external database connection
            </p>
            <p>
                Connections describe how to reach an external analytics
                backend (e.g. ClickHouse). Schema sources can then point
                at this connection to run queries against it.
            </p>
        </field>
    </record>

</odoo>
