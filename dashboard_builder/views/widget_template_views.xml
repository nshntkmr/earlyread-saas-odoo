<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         Widget Template — List View
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_widget_template_list" model="ir.ui.view">
        <field name="name">dashboard.widget.template.list</field>
        <field name="model">dashboard.widget.template</field>
        <field name="arch" type="xml">
            <list string="Widget Templates">
                <field name="name"/>
                <field name="template_mode"/>
                <field name="category"/>
                <field name="chart_type"/>
                <field name="description"/>
                <field name="creates_count" string="# Widgets"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         Widget Template — Form View
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_widget_template_form" model="ir.ui.view">
        <field name="name">dashboard.widget.template.form</field>
        <field name="model">dashboard.widget.template</field>
        <field name="arch" type="xml">
            <form string="Widget Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="template_mode" widget="radio"/>
                            <field name="category"/>
                            <field name="creates_count"/>
                        </group>
                        <group>
                            <field name="preview_image" widget="image" options="{'size': [200, 200]}"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Short description of what this template creates…"/>
                    </group>

                    <!-- ── Parameterized mode ─────────────────────────── -->
                    <group invisible="template_mode != 'parameterized'">
                        <group string="Widget Defaults">
                            <field name="chart_type"/>
                            <field name="col_span"/>
                            <field name="chart_height"/>
                            <field name="color_palette"/>
                        </group>
                        <group string="KPI Formatting">
                            <field name="kpi_format"/>
                            <field name="kpi_prefix" placeholder="e.g. $"/>
                            <field name="kpi_suffix" placeholder="e.g. %"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ─── Legacy JSON tab ───────────────────────── -->
                        <page string="Widget Configs (JSON)" name="configs"
                              invisible="template_mode != 'legacy_json'">
                            <field name="widget_configs"
                                   widget="ace"
                                   options="{'mode': 'json'}"
                                   placeholder='[&#10;  {"chart_type": "kpi", "name": "My KPI", "col_span": "3", ...}&#10;]'/>
                        </page>

                        <!-- ─── SQL Pattern tab ───────────────────────── -->
                        <page string="SQL Pattern" name="sql_pattern"
                              invisible="template_mode != 'parameterized'">
                            <group>
                                <field name="title_pattern"
                                       placeholder="e.g. Total {{metric_label}}"/>
                                <field name="where_clause_exclude"
                                       placeholder="e.g. year,hha_state  (comma-separated)"/>
                            </group>
                            <field name="sql_pattern"
                                   widget="ace"
                                   options="{'mode': 'sql'}"
                                   placeholder="SELECT SUM({{metric_column}}) AS value&#10;FROM {{schema_table}}&#10;WHERE {where_clause}"
                                   nolabel="1"/>
                        </page>

                        <!-- ─── Slots tab ─────────────────────────────── -->
                        <page string="Slots" name="slots"
                              invisible="template_mode != 'parameterized'">
                            <field name="slot_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="slot_name"/>
                                    <field name="label"/>
                                    <field name="slot_type"/>
                                    <field name="column_filter"
                                           invisible="slot_type != 'column'"/>
                                    <field name="required"/>
                                    <field name="default_value"/>
                                    <field name="help_text"/>
                                </list>
                            </field>
                        </page>

                        <!-- ─── Multi-Instance tab ────────────────────── -->
                        <page string="Multi-Instance" name="multi_instance"
                              invisible="template_mode != 'parameterized'">
                            <div class="text-muted mb-2">
                                JSON array — each object creates one widget.
                                Keys must match slot names.
                            </div>
                            <field name="multi_instance_configs"
                                   widget="ace"
                                   options="{'mode': 'json'}"
                                   placeholder='[&#10;  {"metric_column": "total_admits", "metric_label": "Total Admits"},&#10;  {"metric_column": "total_hha_days", "metric_label": "HHA Days"}&#10;]'/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         Widget Template — Action
         ══════════════════════════════════════════════════════════════════════ -->
    <record id="action_widget_template" model="ir.actions.act_window">
        <field name="name">Widget Templates</field>
        <field name="res_model">dashboard.widget.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first widget template
            </p>
            <p>
                Templates contain pre-built widget configurations that can be
                applied to any dashboard page with a single click.
            </p>
        </field>
    </record>

</odoo>
