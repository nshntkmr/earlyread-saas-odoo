<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="designer_page" name="Dashboard Designer">
        <html>
        <head>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <title>Dashboard Designer</title>
            <!-- Bootstrap 5 (bundled with Odoo) -->
            <link rel="stylesheet" href="/web/static/lib/bootstrap/dist/css/bootstrap.css"/>
            <!-- Font Awesome 4 -->
            <link rel="stylesheet" href="/web/static/src/libs/fontawesome/css/font-awesome.css"/>
            <!-- Designer CSS -->
            <link rel="stylesheet"
                  href="/dashboard_builder/static/src/designer/dist/main.css"/>
            <style>
                body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
                #designer-root { min-height: 100vh; }
                .dd-loading { display: flex; align-items: center; justify-content: center;
                              height: 100vh; font-size: 18px; color: #6b7280; }
            </style>
        </head>
        <body>
            <div id="designer-root"
                 t-att-data-api-base="api_base"
                 t-att-data-user-name="user_name"
                 t-att-data-apps="apps_json">
                <div class="dd-loading">
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    Loading Dashboard Designer…
                </div>
            </div>

            <!-- Designer React bundle -->
            <script type="text/javascript"
                    src="/dashboard_builder/static/src/designer/dist/designer.js"></script>
        </body>
        </html>
    </template>

</odoo>
